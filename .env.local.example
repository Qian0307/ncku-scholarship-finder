# 複製成 .env.local 後填入你的 Google Gemini API 金鑰
# 取得：https://aistudio.google.com/apikey
GEMINI_API_KEY=

# 可選：解析器輪替使用的 Gemini 模型清單（逗號分隔，預設如下）。
# 免費版各模型有獨立 RPM 桶，輪替可維持速度、避免 429。
# GEMINI_MODELS=gemini-2.5-flash,gemini-flash-lite-latest,gemini-2.0-flash-lite,gemini-2.0-flash

# 可選：每次呼叫間隔毫秒（預設 1200）
# GEMINI_DELAY_MS=1200

