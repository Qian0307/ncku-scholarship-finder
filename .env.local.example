# 複製成 .env.local 後填入你的 Google Gemini API 金鑰
# 取得：https://aistudio.google.com/apikey
GEMINI_API_KEY=

# 可選：解析器輪替使用的 Gemini 模型清單（逗號分隔，預設如下）。
# 免費版各模型有獨立 RPM 桶，輪替可維持速度、避免 429。
# GEMINI_MODELS=gemini-2.5-flash,gemini-flash-lite-latest,gemini-2.0-flash-lite,gemini-2.0-flash

# 可選：每次呼叫間隔毫秒（預設 1200）
# GEMINI_DELAY_MS=1200

# ── 前端（build 時注入，NEXT_PUBLIC_ 前綴會打包進靜態頁面）──

# 正式網址（結尾不加斜線）。影響 sitemap、robots、OG 分享卡的絕對連結。
# 綁定自訂網域後改成該網域。預設：https://ncku-scholarship-finder.pages.dev
# NEXT_PUBLIC_SITE_URL=https://ncku-scholarship-finder.pages.dev

# 可選：Cloudflare Web Analytics beacon token（在 CF 後台建立後填入才會載入分析）
# NEXT_PUBLIC_CF_ANALYTICS_TOKEN=

# 可選：帳號與跨裝置同步（Supabase）。兩者都設定才會啟用登入功能；未設定則維持純本機模式。
# 於 Supabase 專案 → Settings → API 取得
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=（anon public key）

